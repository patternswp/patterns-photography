{
    "version": 3,
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "color": {
            "custom": true,
            "palette": [
                {
                    "_comment": "Add a color selection palette to the sidebar inspector and configure a custom CSS variable, i.e, --wp--preset--color--{slug}, which is equivalent to --wp--preset--color--base",
                    "color": "#383838",
                    "name": "Base",
                    "slug": "base"
                },
                {
                    "_comment": "Add a color selection palette to the sidebar inspector and configure a custom CSS variable, i.e, --wp--preset--color--{slug}, which is equivalent to --wp--preset--color--default",
                    "color": "#ffffff",
                    "name": "Default",
                    "slug": "default"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--primary",
                    "color": "#FBB42F",
                    "name": "Primary",
                    "slug": "primary"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--secondary",
                    "color": "#070812",
                    "name": "Secondary",
                    "slug": "secondary"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--quinary",
                    "color": "#616a64",
                    "name": "Tertiary",
                    "slug": "tertiary"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--quaternary",
                    "color": "#525252",
                    "name": "Quaternary",
                    "slug": "quaternary"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--quinary",
                    "color": "#F8F8F4",
                    "name": "Quinary",
                    "slug": "quinary"
                },
                {
                    "_comment": "add color palette in sidebar inspector & also auto create css variable i.e --wp--preset--color--{slug} = --wp--preset--color--accent",
                    "color": "#FA6350",
                    "name": "Accent",
                    "slug": "accent"
                }
            ],
            "duotone": [
                {
                    "colors": [
                        "#383838",
                        "#fbb42f"
                    ],
                    "slug": "base-to-primary",
                    "name": "Base to Primary"
                },
                {
                    "colors": [
                        "#383838",
                        "#070812"
                    ],
                    "slug": "base-to-secondary",
                    "name": "Base to Secondary"
                },
                {
                    "colors": [
                        "#ffffff",
                        "#fbb42f"
                    ],
                    "slug": "white-to-primary",
                    "name": "White to Primary"
                },
                {
                    "colors": [
                        "#ffffff",
                        "#fa6350"
                    ],
                    "slug": "white-to-accent",
                    "name": "White to Accent"
                },
                {
                    "colors": [
                        "#616a64",
                        "#070812"
                    ],
                    "slug": "tertiary-to-secondary",
                    "name": "Tertiary to Secondary"
                },
                {
                    "colors": [
                        "#383838",
                        "#f8f8f4"
                    ],
                    "slug": "base-to-quinary",
                    "name": "Base to Quinary"
                }
            ]
        },
        "layout": {
            "contentSize": "850px",
            "wideSize": "1320px"
        },
        "spacing": {
            "defaultSpacingSizes": false,
            "spacingSizes": [
                {
                    "name": "Tiny",
                    "size": "10px",
                    "slug": "10"
                },
                {
                    "name": "X-Small",
                    "size": "20px",
                    "slug": "20"
                },
                {
                    "name": "Small",
                    "size": "clamp(15px, 5vw, 30px);",
                    "slug": "30"
                },
                {
                    "name": "Medium",
                    "size": "clamp(40px, 5vw, 40px);",
                    "slug": "40"
                },
                {
                    "name": "Regular",
                    "size": "clamp(25px, 5vw, 50px);",
                    "slug": "50"
                },
                {
                    "name": "Large",
                    "size": "clamp(30px, 7vw, 60px);",
                    "slug": "60"
                },
                {
                    "name": "X-Large",
                    "size": "clamp(35px, 7vw, 70px);",
                    "slug": "70"
                },
                {
                    "name": "XX-Large",
                    "size": "clamp(40px, 10vw, 80px);",
                    "slug": "80"
                }
            ],
            "units": [
                "%",
                "px",
                "em",
                "rem",
                "vh",
                "vw"
            ]
        },
        "typography": {
            "defaultFontSizes": false,
            "fontFamilies": [
                {
                    "fontFamily": "Cormorant Infant",
                    "slug": "heading",
                    "fontFace": [
                        {
                            "fontFamily": "Cormorant Infant",
                            "fontStyle": "normal",
                            "fontWeight": "300",
                            "src": [
                                "file:./assets/fonts/cormorant-infant/CormorantInfant-Light.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Cormorant Infant",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "src": [
                                "file:./assets/fonts/cormorant-infant/CormorantInfant-Regular.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Cormorant Infant",
                            "fontStyle": "normal",
                            "fontWeight": "500",
                            "src": [
                                "file:./assets/fonts/cormorant-infant/CormorantInfant-Medium.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Cormorant Infant",
                            "fontStyle": "normal",
                            "fontWeight": "600",
                            "src": [
                                "file:./assets/fonts/cormorant-infant/CormorantInfant-SemiBold.woff2"
                            ]
                        },
                        {
                            "fontFamily": "Cormorant Infant",
                            "fontStyle": "normal",
                            "fontWeight": "700",
                            "src": [
                                "file:./assets/fonts/cormorant-infant/CormorantInfant-Bold.woff2"
                            ]
                        }
                    ]
                },
                {
                    "fontFamily": "League Spartan",
                    "slug": "base",
                    "fontFace": [
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "100",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Thin.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "200",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-ExtraLight.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "300",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Light.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "400",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Regular.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "500",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Medium.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "600",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-SemiBold.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "700",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Bold.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "800",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-ExtraBold.woff2"
                            ]
                        },
                        {
                            "fontFamily": "League Spartan",
                            "fontStyle": "normal",
                            "fontWeight": "900",
                            "src": [
                                "file:./assets/fonts/league-spartan/LeagueSpartan-Black.woff2"
                            ]
                        }
                    ]
                }
            ],
            "fontSizes": [
                {
                    "_comment": "The default WordPress CSS variable slug is 'small' and it is generated as '--wp--preset--font-size--x-small' ",
                    "fluid": {
                        "max": "1.063rem",
                        "min": "0.875rem"
                    },
                    "size": "1.063rem",
                    "slug": "x-small",
                    "name": "Extra Small"
                },
                {
                    "_comment": "The default WordPress CSS variable slug is 'small' and it is generated as '--wp--preset--font-size--small' ",
                    "fluid": {
                        "max": "1.375rem",
                        "min": "1.25rem"
                    },
                    "size": "1.75rem",
                    "slug": "small",
                    "name": "Small"
                },
                {
                    "_comment": "The default WordPress CSS variable slug is 'medium' and it is generated as '--wp--preset--font-size--medium' ",
                    "fluid": {
                        "max": "2rem",
                        "min": "1.125rem"
                    },
                    "size": "2rem",
                    "slug": "medium",
                    "name": "Medium"
                },
                {
                    "_comment": "The default WordPress CSS variable slug is 'large' and it is generated as '--wp--preset--font-size--large' ",
                    "fluid": {
                        "max": "2.75rem",
                        "min": "2.50rem"
                    },
                    "size": "2.75rem",
                    "slug": "large",
                    "name": "Large"
                },
                {
                    "_comment": "The default WordPress CSS variable slug is 'x-large' and it is generated as '--wp--preset--font-size--x-large' ",
                    "fluid": {
                        "max": "3.5rem",
                        "min": "2rem"
                    },
                    "size": "3.5rem",
                    "slug": "x-large",
                    "name": "Extra Large"
                },
                {
                    "_comment": "There isn't a default CSS variable slug in WordPress for 'xx-large,' but it gets generated as '--wp--preset--font-size--xx-large.' ' ",
                    "fluid": {
                        "max": "6rem",
                        "min": "3.81rem"
                    },
                    "size": "6rem",
                    "slug": "xx-large",
                    "name": "Extra Extra Large"
                }
            ]
        },
        "blocks": {
            "core/query-no-results": {
                "border": {
                    "_comment": "enable border properties except border-radius",
                    "color": true,
                    "radius": true,
                    "style": true,
                    "width": true
                }
            }
        }
    },
    "styles": {
        "color": {
            "text": "var:preset|color|base",
            "background": "var:preset|color|default"
        },
        "spacing": {
            "padding": {
                "left": "var(--wp--preset--spacing--30)",
                "right": "var(--wp--preset--spacing--30)"
            },
            "blockGap": "1.5rem"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|base",
            "fontSize": "var:preset|font-size|small",
            "lineHeight": "1.3"
        },
        "elements": {
            "button": {
                ":hover": {
                    "color": {
                        "background": "var:preset|color|secondary"
                    },
                    "border": {
                        "color": "var:preset|color|secondary"
                    }
                },
                "border": {
                    "radius": "0"
                },
                "color": {
                    "background": "var:preset|color|primary"
                },
                "spacing": {
                    "padding": {
                        "_comment": "Sets the default padding value of the <button> element",
                        "bottom": "15px",
                        "left": "var:preset|spacing|30",
                        "right": "var:preset|spacing|30",
                        "top": "15px"
                    }
                },
                "typography": {
                    "fontFamily": "var:preset|font-family|base",
                    "fontSize": "0.813rem",
                    "fontWeight": "500",
                    "lineHeight": "1.5",
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|xx-large",
                    "lineHeight": "0.8"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-large",
                    "lineHeight": "1"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|large"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|medium"
                }
            },
            "h5": {
                "typography": {
                    "fontSize": "var:preset|font-size|samll",
                    "fontWeight": "700"
                }
            },
            "h6": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-small"
                }
            },
            "heading": {
                "typography": {
                    "fontFamily": "var:preset|font-family|heading",
                    "fontWeight": "800",
                    "lineHeight": "1"
                },
                "spacing": {
                    "margin": {
                        "_comment": "Sets the default margin value of the heading element i.e h1-h6",
                        "top": "25px",
                        "bottom": "25px"
                    }
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|primary"
                },
                "typography": {
                    "fontFamily": "var:preset|font-family|base",
                    "textDecoration": "none"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|quaternary"
                    },
                    "typography": {
                        "textDecoration": "underline"
                    }
                },
                ":active": {
                    "color": {
                        "text": "var:preset|color|quaternary"
                    },
                    "typography": {
                        "textDecoration": "none"
                    }
                },
                ":focus": {
                    "typography": {
                        "textDecoration": "underline dashed"
                    }
                }
            }
        },
        "blocks": {
            "core/paragraph": {
                "css": "&:not(:last-child){ margin-bottom:15px;} "
            },
            "core/navigation": {
                "_comment": "generate custom css for navigation active state",
                "spacing": {
                    "blockGap": "var:preset|spacing|40"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|x-small",
                    "fontWeight": "600",
                    "textTransform": "uppercase",
                    "fontStyle": "normal",
                    "letterSpacing": "1px"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        },
                        ":active": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        },
                        ":focus": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        }
                    }
                },
                "css": "& .current-menu-item{ color:var(--wp--preset--color--primary);} & .wp-block-navigation__submenu-container .wp-block-pages-list__item__link{ padding:var(--wp--preset--spacing--10);}"
            },
            "core/navigation-link": {
                "elements": {
                    "link": {
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        }
                    }
                }
            },
            "core/navigation-submenu": {
                "css": "& ul li a{padding:var(--wp--preset--spacing--10);}"
            },
            "core/button": {
                "variations": {
                    "outline": {
                        "border": {
                            "color": "var:preset|color|primary",
                            "style": "solid",
                            "width": "1px"
                        },
                        "color": {
                            "text": "var:preset|color|primary"
                        },
                        "css": ".wp-block-button__link:not(.has-background):hover {background:var(--wp--preset--color--primary);color: var(--wp--preset--color--default);}",
                        "spacing": {
                            "padding": {
                                "bottom": "15px",
                                "left": "var:preset|spacing|30",
                                "right": "var:preset|spacing|30",
                                "top": "15px"
                            }
                        }
                    }
                }
            },
            "core/site-title": {
                "typography": {
                    "textTransform": "uppercase",
                    "fontStyle": "normal",
                    "fontWeight": "700",
                    "lineHeight": "1.1",
                    "fontSize": "1.2rem"
                },
                "spacing": {
                    "margin": {
                        "bottom": "0px"
                    }
                },
                "elements": {
                    "link": {
                        "typography": {
                            "textDecoration": "none"
                        },
                        "color": {
                            "text": "var:preset|color|base"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|primary"
                            },
                            "typography": {
                                "textDecoration": "underline"
                            }
                        }
                    }
                }
            },
            "core/site-tagline": {
                "typography": {
                    "textTransform": "uppercase",
                    "letterSpacing": "1px"
                },
                "color": {
                    "text": "var:preset|color|base"
                }
            },
            "core/code": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-small",
                    "lineHeight": "1.3"
                }
            },
            "core/quote": {
                "border": {
                    "color": "var:preset|color|primary"
                },
                "spacing": {
                    "margin": {
                        "_comment": "Sets the default margin bottom value",
                        "bottom": "15px"
                    }
                }
            },
            "core/pullquote": {
                "border": {
                    "color": "var:preset|color|tertiary"
                }
            },
            "core/categories": {
                "color": {
                    "text": "var:preset|color|tertiary"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|base"
                        }
                    }
                }
            },
            "core/post-title": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|large"
                },
                "spacing": {
                    "margin": {
                        "top": "0",
                        "bottom": "0"
                    }
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|base"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        }
                    }
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var:preset|color|tertiary"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|primary"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|quaternary"
                            }
                        }
                    }
                }
            },
            "core/post-terms": {
                "color": {
                    "text": "var:preset|color|tertiary"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|x-small"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|primary"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|quaternary"
                            }
                        }
                    }
                }
            },
            "core/post-author": {
                "color": {
                    "text": "var:preset|color|tertiary"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|primary"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|quaternary"
                            }
                        }
                    }
                }
            },
            "core/post-excerpt": {
                "color": {
                    "text": "var:preset|color|tertiary"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|primary"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|quaternary"
                            }
                        }
                    }
                }
            },
            "core/post-featured-image": {
                "border": {
                    "radius": "0"
                }
            },
            "core/query-pagination-next": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "elements": {
                    "link": {
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|primary"
                            }
                        }
                    }
                }
            },
            "core/query-pagination": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|base"
                        },
                        "spacing": {
                            "padding": {
                                "bottom": "var:preset|spacing|10",
                                "left": "15px",
                                "right": "15px",
                                "top": "var:preset|spacing|10"
                            },
                            "margin": {
                                "bottom": "2px",
                                "left": "2px",
                                "right": "2px",
                                "top": "2px"
                            }
                        },
                        "border": {
                            "color": "var:preset|color|quinary",
                            "style": "solid",
                            "width": "1px",
                            "radius": "5px"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|default",
                                "background": "var:preset|color|primary"
                            },
                            "typography": {
                                "textDecoration": "none"
                            },
                            "border": {
                                "color": "var:preset|color|primary",
                                "radius": "5px"
                            }
                        }
                    }
                },
                "css": "& .page-numbers:is(.dots, .current){padding:var(--wp--preset--spacing--10) 15px; border:1px solid var(--wp--preset--color--quinary); border-radius:5px;} & .current{background:var(--wp--preset--color--primary); color: var(--wp--preset--color--default);} "
            },
            "core/query-no-results": {
                "color": {
                    "background": "var:preset|color|quinary"
                },
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|40",
                        "right": "var:preset|spacing|40",
                        "bottom": "var:preset|spacing|40",
                        "left": "var:preset|spacing|40"
                    },
                    "margin": {
                        "top": "var:preset|spacing|80"
                    }
                },
                "border": {
                    "color": "#aaaaaa",
                    "radius": "5px",
                    "style": "solid",
                    "width": "1px"
                }
            },
            "core/comment-template": {
                "spacing": {
                    "padding": {
                        "top": "var:preset|spacing|40",
                        "bottom": "var:preset|spacing|40"
                    },
                    "margin": {
                        "bottom": "var:preset|spacing|30"
                    }
                }
            },
            "core/comment-author-name": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "typography": {
                    "fontSize": "var:preset|font-size|x-small",
                    "fontWeight": "600"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|base"
                        },
